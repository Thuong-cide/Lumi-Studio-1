# ─── Database ────────────────────────────────────────────────────────────────
# Nếu PostgreSQL chạy trực tiếp trên NAS (không phải Docker):
#   Host là host.docker.internal để container kết nối ra ngoài
# Ví dụ: postgresql://username:password@host.docker.internal:5432/lumiere
DATABASE_URL=postgresql://lumiere_user:your_password@host.docker.internal:5432/lumiere_db

# ─── Auth ────────────────────────────────────────────────────────────────────
# Chuỗi bí mật bất kỳ, dài ít nhất 32 ký tự
JWT_SECRET=thay-bang-chuoi-bi-mat-cua-ban-it-nhat-32-ky-tu

# ─── Google Drive ─────────────────────────────────────────────────────────────
# Tạo tại: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxx
# Thay NAS_IP bằng IP hoặc domain NAS của bạn
GOOGLE_REDIRECT_URI=http://NAS_IP:9001/api/auth/google/callback
